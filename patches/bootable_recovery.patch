+	property_get("sys.usb.controller", controller, "a600000.dwc3");
+	std::string cmd =
+		"sh -c '"
+		"echo none > /config/usb_gadget/g1/UDC 2>/dev/null || true; "
+		"rm -f /config/usb_gadget/g1/configs/b.1/function0 "
+		"/config/usb_gadget/g1/configs/b.1/function1 "
+		"/config/usb_gadget/g1/configs/b.1/f1 "
+		"/config/usb_gadget/g1/configs/b.1/f2 "
+		"/config/usb_gadget/g1/configs/b.1/f3; "
+		"echo adb > /config/usb_gadget/g1/configs/b.1/strings/0x409/configuration; "
+		"echo 0x18D1 > /config/usb_gadget/g1/idVendor; "
+		"echo 0x4E11 > /config/usb_gadget/g1/idProduct; "
+		"ln -s /config/usb_gadget/g1/functions/ffs.adb /config/usb_gadget/g1/configs/b.1/f1; "
+		"echo " + std::string(controller) + " > /config/usb_gadget/g1/UDC 2>/dev/null || true; "
+		"setprop sys.usb.state adb; "
+		"setprop twrp.usb.mtp_configured 0"
+		"'";
+	LOGINFO("MTP: restoring adb-only configfs on %s\n", controller);
+	TWFunc::Exec_Cmd(cmd, false);
+}
+
+static void Get_Mtp_Adb_Usb_Ids(std::string* vendor, std::string* product) {
+	*vendor = "0x2717";
+	*product = "0xFF48";
+}
