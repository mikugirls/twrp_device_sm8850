+static string FindCpuTempFile() {
+	const string thermal_dir = "/sys/class/thermal";
+	const string preferred_type = "cpu_therm";
+	const string fallback_prefix = "cpu-";
+	string fallback;
+	DIR* dir = opendir(thermal_dir.c_str());
+	if (dir) {
+		struct dirent* de;
+		while ((de = readdir(dir)) != NULL) {
+			if (strncmp(de->d_name, "thermal_zone", 12) != 0)
+				continue;
+			string zone = thermal_dir + "/" + de->d_name;
+			string type;
+			if (TWFunc::read_file(zone + "/type", type) != 0)
+				continue;
+			type.erase(type.find_last_not_of(" \n\r\t") + 1);
+			if (type == preferred_type) {
+				closedir(dir);
+				return zone + "/temp";
+			}
+			if (fallback.empty() && type.rfind(fallback_prefix, 0) == 0)
+				fallback = zone + "/temp";
+		}
+		closedir(dir);
+	}
+	if (!fallback.empty())
+		return fallback;
+#ifdef TW_CUSTOM_CPU_TEMP_PATH
+	return EXPAND(TW_CUSTOM_CPU_TEMP_PATH);
+#else
+	return "/sys/class/thermal/thermal_zone0/temp";
+#endif
+}
