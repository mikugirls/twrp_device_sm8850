+static int vibrate_qcom_haptics(int timeout_ms)
+{
+	if (timeout_ms <= 0)
+		return 0;
+	if (timeout_ms > 120)
+		timeout_ms = 120;
+	if (access(QCOM_HAPTICS_PLAY_FILE, W_OK) != 0)
+		return -1;
+
+	write_to_file(QCOM_HAPTICS_PLAY_FILE, "0");
+	if (write_to_file(QCOM_HAPTICS_DURATION_FILE, std::to_string(timeout_ms)) < 0)
+		return -1;
+	return write_to_file(QCOM_HAPTICS_PLAY_FILE, "1");
+}
+
+static int vibrate_input_ff(int timeout_ms)
+{
+	static int ff_fd = -1;
+	static int ff_effect_id = -1;
+	static int ff_effect_len = 0;
+
+	if (timeout_ms <= 0)
+		return 0;
+	if (timeout_ms > 120)
+		timeout_ms = 120;
+
+	auto setup_effect = [](int fd, int timeout_ms, struct ff_effect* effect) {
+		static int16_t custom_data[] = { 0, 0, 0 };
+
+		for (int id = 0; id <= 5; id++) {
+			custom_data[0] = id;
+			memset(effect, 0, sizeof(*effect));
+			effect->type = FF_PERIODIC;
+			effect->id = -1;
+			effect->u.periodic.waveform = FF_CUSTOM;
+			effect->u.periodic.period = timeout_ms;
+			effect->u.periodic.magnitude = 0x5000;
+			effect->u.periodic.custom_len = sizeof(custom_data);
+			effect->u.periodic.custom_data = custom_data;
+			effect->replay.length = timeout_ms;
+
+			if (ioctl(fd, EVIOCSFF, effect) == 0) {
+				LOGI("Input FF haptics uploaded FF_CUSTOM effect id %d as slot %d\n", id, effect->id);
+				return 0;
+			}
+			LOGI("Input FF haptics FF_CUSTOM effect id %d upload failed: %s\n", id, strerror(errno));
+		}
+
+		memset(effect, 0, sizeof(*effect));
+		effect->type = FF_CONSTANT;
+		effect->id = -1;
+		effect->u.constant.level = 0x5000;
+		effect->replay.length = timeout_ms;
+		if (ioctl(fd, EVIOCSFF, effect) == 0) {
+			LOGI("Input FF haptics uploaded FF_CONSTANT as slot %d\n", effect->id);
+			return 0;
+		}
+		LOGI("Input FF haptics FF_CONSTANT upload failed: %s\n", strerror(errno));
+
+		memset(effect, 0, sizeof(*effect));
+		effect->type = FF_RUMBLE;
+		effect->id = -1;
+		effect->u.rumble.strong_magnitude = 0x5000;
+		effect->u.rumble.weak_magnitude = 0x1800;
+		effect->replay.length = timeout_ms;
+		int ret = ioctl(fd, EVIOCSFF, effect);
+		if (ret < 0)
+			LOGI("Input FF haptics FF_RUMBLE upload failed: %s\n", strerror(errno));
+		return ret;
+	};
+
+	if (ff_fd >= 0) {
+		if (ff_effect_id < 0 || ff_effect_len != timeout_ms) {
+			if (ff_effect_id >= 0)
+				ioctl(ff_fd, EVIOCRMFF, ff_effect_id);
+
+			struct ff_effect effect = {};
+			if (setup_effect(ff_fd, timeout_ms, &effect) < 0) {
+				LOGI("Input FF haptics cached upload failed\n");
+				close(ff_fd);
+				ff_fd = -1;
+				ff_effect_id = -1;
+				ff_effect_len = 0;
+				return -1;
+			}
+			ff_effect_id = effect.id;
+			ff_effect_len = timeout_ms;
+		}
+
+		struct input_event play = {};
+		play.type = EV_FF;
+		play.code = ff_effect_id;
+		play.value = 1;
+		int ret = write(ff_fd, &play, sizeof(play)) == sizeof(play) ? 0 : -1;
+		if (ret < 0)
+			LOGI("Input FF haptics cached playback failed: %s\n", strerror(errno));
+		return ret;
+	}
+
+	for (int i = 0; i < MAX_DEVICES; i++) {
+		char path[32];
+		char name[80] = {};
+		snprintf(path, sizeof(path), "/dev/input/event%d", i);
+
+		int fd = open(path, O_RDWR | O_CLOEXEC);
+		if (fd < 0)
+			continue;
+
+		if (ioctl(fd, EVIOCGNAME(sizeof(name)), name) < 0 ||
+		    strcmp(name, INPUT_FF_HAPTICS_NAME) != 0) {
+			close(fd);
+			continue;
+		}
+
+		LOGI("Using input FF haptics device %s (%s)\n", path, name);
+		struct ff_effect effect = {};
+		if (setup_effect(fd, timeout_ms, &effect) < 0) {
+			LOGI("Input FF haptics upload failed on %s\n", path);
+			close(fd);
+			return -1;
+		}
+
+		struct input_event play = {};
+		play.type = EV_FF;
+		play.code = effect.id;
+		play.value = 1;
+		int ret = write(fd, &play, sizeof(play)) == sizeof(play) ? 0 : -1;
+		if (ret == 0) {
+			LOGI("Input FF haptics playback started with slot %d\n", effect.id);
+			ff_fd = fd;
+			ff_effect_id = effect.id;
+			ff_effect_len = timeout_ms;
+		} else {
+			LOGI("Input FF haptics playback failed on %s: %s\n", path, strerror(errno));
+			close(fd);
+		}
+		return ret;
+	}
+	LOGI("Input FF haptics device %s not found\n", INPUT_FF_HAPTICS_NAME);
+	return -1;
+}
